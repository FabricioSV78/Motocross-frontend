      .max(15)
      .regex(/^[0-9+\s\-()]+$/, 'Invalid phone format'),
    experience: z.string().max(500).optional(),
    password: z.string().min(8, 'At least 8 characters').max(100),
    confirmPassword: z.string().min(1, 'Confirm your password'),
