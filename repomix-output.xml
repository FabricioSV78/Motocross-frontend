  INTERMEDIATE: { label: 'Intermediate', className: 'bg-amber-500/15 text-amber-300 border-amber-500/30' },
  ADVANCED: { label: 'Advanced', className: 'bg-red-500/15 text-red-300 border-red-500/30' },
